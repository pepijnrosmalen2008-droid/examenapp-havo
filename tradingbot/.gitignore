# Secrets — NEVER commit
.env

# Runtime state & data
*.db
*.db-journal
*.db-wal
*.db-shm
data-cache/
logs/
dashboard.html

# Live-mode confirmation file (personal, per machine)
I_UNDERSTAND_THE_RISKS.txt

# Python
__pycache__/
*.pyc
# De hoofd-.gitignore van de site negeert _*.py (Slagio-hulpscripts); die regel
# ving per ongeluk ook __init__.py. Deze negatie zet dat recht voor de bot.
!__init__.py
!**/__init__.py
.pytest_cache/
.venv/
venv/
