# Kopieer dit bestand naar .env en vul in. .env staat in .gitignore en mag NOOIT gecommit worden.

# Bitvavo API key — maak aan op https://account.bitvavo.com/user/api
# BELANGRIJK: geef de key ALLEEN View + Trade rechten. NOOIT Withdrawal.
# Beperk de key op het IP-adres van je server als je dat kunt.
BITVAVO_API_KEY=
BITVAVO_API_SECRET=

# Trading mode guardrail. De bot draait ALTIJD in PAPER tenzij:
#   1. TRADING_MODE=LIVE hieronder is gezet, ÉN
#   2. het bestand I_UNDERSTAND_THE_RISKS.txt in de projectroot bestaat, ÉN
#   3. config.yaml mode: LIVE heeft.
TRADING_MODE=PAPER

# Telegram-notificaties (optioneel — leeg laten om uit te zetten)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webportaal op slagio.nl/bot.html (optioneel — leeg laten om uit te zetten)
# Setup: draai eerst deploy/supabase_portal.sql in de Supabase SQL Editor en
# maak één gebruiker aan (zie de toelichting in dat bestand + README).
# De anon key is dezelfde publieke key als in cloud.js van de site.
SUPABASE_URL=https://wcfenegohryxhatzxvtw.supabase.co
SUPABASE_ANON_KEY=
BOT_PORTAL_EMAIL=
BOT_PORTAL_PASSWORD=
